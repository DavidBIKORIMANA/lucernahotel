<tr><td>--sp-2</td><td>16px</td><td>--sp-6</td><td>48px</td></tr>
<tr><td>--sp-3</td><td>24px</td><td>--sp-8</td><td>64px</td></tr>
<tr><td>--sp-4</td><td>32px</td><td>--max-w</td><td>1340px</td></tr>
</table>

